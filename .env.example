# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma (API + migrations + seed)
DATABASE_URL=postgresql://presspass:presspass@localhost:5432/presspass?schema=public

# ─── API (apps/api) ──────────────────────────────────────────────────────────
# Port the NestJS API listens on
PORT=3001
# Secret used to sign JWT access tokens. MUST be long and random in production.
JWT_SECRET=change-me-to-a-long-random-string
# Legacy migration secret used only to read pre-Stage-1 recovery/editorial envelopes.
# New owner-key envelopes do not depend on it. Preserve its old value until backfill is verified.
DATA_KEY_SECRET=change-me-to-an-independent-long-random-string
# Independent HMAC key for blind indexes (email login lookup); never reuse JWT/DATA keys.
LOOKUP_KEY=change-me-to-a-separate-long-random-lookup-key
# Access token lifetime (e.g. 15m, 1h, 1d)
JWT_EXPIRES_IN=1d
# Allowed CORS origin — URL of the web app
CORS_ORIGIN=http://localhost:3000
# Public base URL used inside QR codes: {VERIFY_BASE_URL}/verify/{uuid}?t=...
VERIFY_BASE_URL=https://id.domain.ua
# Lifetime (seconds) of the signed dynamic-QR token; the app refreshes the QR
# every ~30 s, so keep this at 45–90 s (display period + clock skew).
QR_TOKEN_TTL=60
# Directory where uploaded photos are stored (relative to repo root or absolute)
UPLOADS_DIR=./uploads

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# API key from https://resend.com — used to send registration confirmation
# codes. Leave empty in development: codes are then printed to the API log.
# Can also be set from the admin panel (/admin/settings), which overrides this.
RESEND_API_KEY=
# Sender address; the domain must be verified in Resend.
MAIL_FROM=PressPass <onboarding@resend.dev>

# ─── Google Sign-In (optional) ───────────────────────────────────────────────
# OAuth 2.0 credentials from https://console.cloud.google.com/apis/credentials.
# Leave empty to hide the "Sign in with Google" button.
# Authorized redirect URI: {VERIFY_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Seed (prisma/seed.ts) ───────────────────────────────────────────────────
# Initial administrator account created by the seed script
ADMIN_EMAIL=admin@presspass.local
ADMIN_PASSWORD=ChangeMe_Admin1!
# Separate passphrase that wraps the initial administrator KEK (never reuse ADMIN_PASSWORD).
ADMIN_ENCRYPTION_PASSPHRASE=ChangeMe_Independent_Crypto_Passphrase_1!
# Used only while generating the two encrypted offline recovery kits during initial backfill.
# Do not persist these values in the production .env after the kits have been exported and tested.
SUPERADMIN_RECOVERY_PASSPHRASE_1=ChangeMe_Offline_Recovery_One_1!
SUPERADMIN_RECOVERY_PASSPHRASE_2=ChangeMe_Offline_Recovery_Two_2!
# Must be outside the application/uploads directory and must not already exist.
RECOVERY_KIT_OUTPUT=/tmp/presspass-recovery-kits.json

# ─── Web (apps/web) ──────────────────────────────────────────────────────────
# Base URL of the REST API, as seen from the browser.
# Development: absolute URL of the API process.
# Production behind Nginx: the relative path /api (see docs/deploy.md).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Base URL the Next.js server itself uses to reach the API (SSR of /verify).
# Only needed when NEXT_PUBLIC_API_URL is relative; defaults to http://127.0.0.1:3001.
# API_INTERNAL_URL=http://127.0.0.1:3001
