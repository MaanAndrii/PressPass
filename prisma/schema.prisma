// PressPass Platform — database schema.
// PostgreSQL via Prisma ORM. See docs/database.md for the full description.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITORIAL_ADMIN
  JOURNALIST
}

enum CardStatus {
  ACTIVE
  BLOCKED
  EXPIRED
}

/// Authentication account (both administrators and journalists).
/// password_hash is NULL for Google-only accounts.
model User {
  id                  Int                     @id @default(autoincrement())
  email               String                  @unique
  // Transitional expand/backfill fields. `email` is removed by the contract
  // migration only after every installation has a verified encrypted payload.
  emailBlindIndex     String?                 @unique @map("email_blind_index")
  encryptedData       Json?                   @map("encrypted_data")
  passwordHash        String?                 @map("password_hash")
  // Password-derived key metadata and the user's wrapped profile data key.
  // Both are JSON envelopes; no raw encryption key is persisted.
  passwordKdf         Json?                   @map("password_kdf")
  dataKeyEnvelope     Json?                   @map("data_key_envelope")
  recoveryKeyEnvelope Json?                   @map("recovery_key_envelope")
  // Profile data key sealed (RSA-OAEP) to the system read public key, giving a
  // Superadmin universal online read access. Populated at profile creation and
  // lazily on the owner's next login for pre-existing accounts.
  systemKeyEnvelope   Json?                   @map("system_key_envelope")
  tokenVersion        Int                     @default(0) @map("token_version")
  role                Role                    @default(JOURNALIST)
  emailVerifiedAt     DateTime?               @map("email_verified_at")
  googleId            String?                 @unique @map("google_id")
  googleIdBlindIndex  String?                 @unique @map("google_id_blind_index")
  // For an EDITORIAL_ADMIN, the editorial they administer (else NULL).
  editorialId         Int?                    @map("editorial_id")
  editorial           Editorial?              @relation(fields: [editorialId], references: [id], onDelete: SetNull)
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  journalist          Journalist?
  verification        EmailVerification?
  editorialKeyGrants  EditorialDataKeyGrant[]
  adminKeyMaterial    AdminKeyMaterial?
  superadminKeySlots  SuperadminKeySlot[]     @relation("SuperadminSlotOwner")
  recoveryAuthorities SuperadminRecoveryKey[] @relation("SuperadminRecoveryOwner")

  @@index([editorialId])
  @@map("users")
}

/// A user's data key wrapped for an editorial that currently has membership access.
/// Only an encrypted envelope is persisted; the raw data key never enters Prisma.
model EditorialDataKeyGrant {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  editorialId Int       @map("editorial_id")
  editorial   Editorial @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  keyEnvelope Json      @map("key_envelope")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, editorialId])
  @@map("editorial_data_key_grants")
}

/// One-time email confirmation code sent on self-registration.
model EmailVerification {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_verifications")
}

/// Journalist profile. Photos are stored on disk; only the path is kept here.
/// position/organization are set by the admin; the questionnaire fields
/// (birth_date, passport_data, tax_number, phone) are filled by the user
/// after self-registration and required before a card can be issued.
model Journalist {
  id             Int                   @id @default(autoincrement())
  userId         Int                   @unique @map("user_id")
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Short human-friendly code the journalist gives an admin to be added to a
  // media (e.g. "JR-7K3F9Q"); privacy-preserving alternative to listing all.
  publicId       String                @unique @map("public_id")
  fullName       String                @default("") @map("full_name")
  fullNameEn     String                @default("") @map("full_name_en")
  position       String                @default("")
  positionEn     String                @default("") @map("position_en")
  organization   String                @default("")
  organizationEn String                @default("") @map("organization_en")
  photoPath      String?               @map("photo_path")
  birthDate      DateTime?             @map("birth_date") @db.Date
  passportData   String?               @map("passport_data")
  taxNumber      String?               @map("tax_number")
  phone          String?
  // Член Національної спілки журналістів України — вмикає логотип НСЖУ на картці.
  nszhuMember    Boolean               @default(false) @map("nszhu_member")
  // Основне посвідчення, вибране журналістом (коли їх кілька від різних редакцій).
  primaryCardId  Int?                  @map("primary_card_id")
  selfRegistered Boolean               @default(false) @map("self_registered")
  encryptedData  Json?                 @map("encrypted_data")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  cards          Card[]
  memberships    EditorialMembership[]

  @@map("journalists")
}

/// Catalogue of journalist positions (Ukrainian + English), chosen from a list
/// when a card is issued instead of typing them by hand.
model Position {
  id     Int    @id @default(autoincrement())
  nameUk String @map("name_uk")
  nameEn String @default("") @map("name_en")

  @@map("positions")
}

/// Singleton row holding the active card design template (theme + fields) as
/// JSON, so the credential's appearance can be changed from the admin panel
/// without redeploying. See packages/shared CardTemplate.
model CardTemplate {
  id            Int        @id @default(autoincrement())
  // Editorial this design belongs to; NULL is the system-wide default that
  // editorials inherit when they have no own template.
  editorialId   Int?       @unique @map("editorial_id")
  editorial     Editorial? @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  data          Json
  encryptedData Json?      @map("encrypted_data")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("card_templates")
}

/// Singleton row for runtime-editable settings (e.g. the Resend API key),
/// so an admin can configure email sending from the panel. Values here
/// override the corresponding environment variables when set.
model AppSetting {
  id            Int      @id @default(1)
  resendApiKey  String?  @map("resend_api_key")
  mailFrom      String?  @map("mail_from")
  // Uploaded NSZHU logo path, shown on cards of union members.
  nszhuLogoPath String?  @map("nszhu_logo_path")
  encryptedData Json?    @map("encrypted_data")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

/// Issuing company ("редакція"). An admin manages these; a card is issued on
/// behalf of one, and the card/verify page show its name, logo and the public
/// registry link. Only `name` is required; the rest are optional details.
model Editorial {
  id                         Int                     @id @default(autoincrement())
  name                       String
  displayNameUk              String                  @default("") @map("display_name_uk")
  displayNameEn              String                  @default("") @map("display_name_en")
  // Державний ідентифікатор медіа, напр. R40-02551 (маска ***-*****).
  mediaId                    String                  @default("") @map("media_id")
  // Нумерація посвідчень цієї редакції: унікальний префікс + шаблон із токенів.
  cardNumberPrefix           String                  @default("") @map("card_number_prefix")
  cardNumberTemplate         String                  @default("{prefix}-{year}-{seq:6}") @map("card_number_template")
  edrpou                     String                  @default("")
  website                    String                  @default("")
  logoPath                   String?                 @map("logo_path")
  director                   String                  @default("")
  email                      String                  @default("")
  address                    String                  @default("")
  phone                      String                  @default("")
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  cards                      Card[]
  admins                     User[]
  cardTemplate               CardTemplate?
  members                    EditorialMembership[]
  dataKeyGrants              EditorialDataKeyGrant[]
  encryptedData              Json?                   @map("encrypted_data")
  cardNumberPrefixBlindIndex String?                 @unique @map("card_number_prefix_blind_index")
  keyMaterial                EditorialKeyMaterial?
  encryptedFiles             EncryptedFile[]

  @@map("editorials")
}

/// Membership linking a journalist to a media (many-to-many). An editorial
/// admin only sees journalists who are members of their editorial; a journalist
/// is added by giving their public_id to the admin (or on card issuance).
model EditorialMembership {
  id           Int        @id @default(autoincrement())
  editorialId  Int        @map("editorial_id")
  editorial    Editorial  @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  journalistId Int        @map("journalist_id")
  journalist   Journalist @relation(fields: [journalistId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([editorialId, journalistId])
  @@index([journalistId])
  @@map("editorial_memberships")
}

/// Press credential. `uuid` (UUIDv7) is the only identifier exposed in QR codes.
model Card {
  id                   Int        @id @default(autoincrement())
  uuid                 String     @unique @db.Uuid
  journalistId         Int        @map("journalist_id")
  journalist           Journalist @relation(fields: [journalistId], references: [id], onDelete: Cascade)
  editorialId          Int?       @map("editorial_id")
  editorial            Editorial? @relation(fields: [editorialId], references: [id], onDelete: SetNull)
  // Position on this card, set by the issuing editorial (both languages).
  position             String     @default("")
  positionEn           String     @default("") @map("position_en")
  cardNumber           String     @unique @map("card_number")
  // Per-editorial, per-year sequence used to build cardNumber (0 for legacy).
  numberSeq            Int        @default(0) @map("number_seq")
  issueDate            DateTime?  @map("issue_date") @db.Date
  expireDate           DateTime?  @map("expire_date") @db.Date
  status               CardStatus @default(ACTIVE)
  encryptedData        Json?      @map("encrypted_data")
  cardNumberBlindIndex String?    @unique @map("card_number_blind_index")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@index([journalistId])
  @@index([editorialId])
  @@map("cards")
}

/// A random administrator KEK wrapped by a key derived from the administrator's
/// distinct encryption passphrase. No raw administrator key is persisted.
model AdminKeyMaterial {
  id             Int                     @id @default(autoincrement())
  userId         Int                     @unique @map("user_id")
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyVersion     Int                     @default(1) @map("key_version")
  passphraseKdf  Json                    @map("passphrase_kdf")
  keyEnvelope    Json                    @map("key_envelope")
  fingerprint    String                  @unique
  createdAt      DateTime                @default(now()) @map("created_at")
  revokedAt      DateTime?               @map("revoked_at")
  editorialSlots EditorialAdminKeySlot[]
  systemSlots    SystemAdminKeySlot[]

  @@map("admin_key_material")
}

/// Random KEK protecting global settings and the default card template.
///
/// It also holds the system READ key: an RSA keypair whose public key seals
/// every profile data key (so a Superadmin gains universal online read access
/// without editorial grants), while the private key is stored only encrypted
/// under the System KEK — a database dump alone still reveals nothing.
model SystemKeyMaterial {
  id                     Int                  @id @default(1)
  keyVersion             Int                  @default(1) @map("key_version")
  fingerprint            String               @unique
  /// SPKI PEM of the system read public key (safe to store in the clear).
  readPublicKey          String?              @map("read_public_key")
  /// PKCS8 private key PEM, AES-256-GCM encrypted under the System KEK.
  readPrivateKeyEnvelope Json?                @map("read_private_key_envelope")
  createdAt              DateTime             @default(now()) @map("created_at")
  rotatedAt              DateTime?            @map("rotated_at")
  adminSlots             SystemAdminKeySlot[]

  @@map("system_key_material")
}

model SystemAdminKeySlot {
  id          Int               @id @default(autoincrement())
  systemKeyId Int               @map("system_key_id")
  systemKey   SystemKeyMaterial @relation(fields: [systemKeyId], references: [id], onDelete: Cascade)
  adminKeyId  Int               @map("admin_key_id")
  adminKey    AdminKeyMaterial  @relation(fields: [adminKeyId], references: [id], onDelete: Cascade)
  keyEnvelope Json              @map("key_envelope")
  createdAt   DateTime          @default(now()) @map("created_at")
  revokedAt   DateTime?         @map("revoked_at")

  @@unique([systemKeyId, adminKeyId])
  @@map("system_admin_key_slots")
}

/// One random KEK per editorial. The raw key is available only by unwrapping
/// one of its administrator slots (or an authorized Superadmin recovery slot).
model EditorialKeyMaterial {
  id          Int                     @id @default(autoincrement())
  editorialId Int                     @unique @map("editorial_id")
  editorial   Editorial               @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  keyVersion  Int                     @default(1) @map("key_version")
  fingerprint String                  @unique
  createdAt   DateTime                @default(now()) @map("created_at")
  rotatedAt   DateTime?               @map("rotated_at")
  adminSlots  EditorialAdminKeySlot[]

  @@map("editorial_key_material")
}

/// The same Editorial KEK independently wrapped for one active administrator.
model EditorialAdminKeySlot {
  id             Int                  @id @default(autoincrement())
  editorialKeyId Int                  @map("editorial_key_id")
  editorialKey   EditorialKeyMaterial @relation(fields: [editorialKeyId], references: [id], onDelete: Cascade)
  adminKeyId     Int                  @map("admin_key_id")
  adminKey       AdminKeyMaterial     @relation(fields: [adminKeyId], references: [id], onDelete: Cascade)
  keyEnvelope    Json                 @map("key_envelope")
  createdAt      DateTime             @default(now()) @map("created_at")
  revokedAt      DateTime?            @map("revoked_at")

  @@unique([editorialKeyId, adminKeyId])
  @@map("editorial_admin_key_slots")
}

/// Public recovery authority. Only the RSA public key is persisted; the
/// passphrase-encrypted private key is emitted once in an offline kit.
model SuperadminRecoveryKey {
  id               Int                 @id @default(autoincrement())
  superadminUserId Int                 @map("superadmin_user_id")
  superadmin       User                @relation("SuperadminRecoveryOwner", fields: [superadminUserId], references: [id], onDelete: Cascade)
  slotNumber       Int                 @map("slot_number")
  publicKey        String              @map("public_key")
  fingerprint      String              @unique
  createdAt        DateTime            @default(now()) @map("created_at")
  revokedAt        DateTime?           @map("revoked_at")
  ownerSlots       SuperadminKeySlot[]

  @@unique([superadminUserId, slotNumber])
  @@map("superadmin_recovery_keys")
}

/// An owner DEK sealed independently to one Superadmin RSA public key.
model SuperadminKeySlot {
  id               Int                   @id @default(autoincrement())
  superadminUserId Int                   @map("superadmin_user_id")
  superadmin       User                  @relation("SuperadminSlotOwner", fields: [superadminUserId], references: [id], onDelete: Cascade)
  recoveryKeyId    Int                   @map("recovery_key_id")
  recoveryKey      SuperadminRecoveryKey @relation(fields: [recoveryKeyId], references: [id], onDelete: Cascade)
  ownerType        String                @map("owner_type")
  ownerId          String                @map("owner_id")
  slotNumber       Int                   @map("slot_number")
  keyVersion       Int                   @default(1) @map("key_version")
  keyEnvelope      Json                  @map("key_envelope")
  createdAt        DateTime              @default(now()) @map("created_at")
  revokedAt        DateTime?             @map("revoked_at")

  @@unique([ownerType, ownerId, slotNumber])
  @@index([superadminUserId])
  @@index([recoveryKeyId])
  @@map("superadmin_key_slots")
}

/// Metadata for an encrypted durable blob. Ciphertext lives under an opaque
/// storage name; its random file DEK is wrapped by the owning DEK.
model EncryptedFile {
  id              String     @id @default(uuid()) @db.Uuid
  ownerType       String     @map("owner_type")
  ownerId         String     @map("owner_id")
  editorialId     Int?       @map("editorial_id")
  editorial       Editorial? @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  purpose         String
  storageName     String     @unique @map("storage_name")
  mimeType        String     @map("mime_type")
  byteLength      Int        @map("byte_length")
  contentEnvelope Json       @map("content_envelope")
  fileKeyEnvelope Json       @map("file_key_envelope")
  createdAt       DateTime   @default(now()) @map("created_at")
  replacedAt      DateTime?  @map("replaced_at")

  @@index([ownerType, ownerId, purpose])
  @@map("encrypted_files")
}
